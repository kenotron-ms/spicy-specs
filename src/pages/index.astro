---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allSpecs = await getCollection('specs');

const specs = allSpecs.sort((a, b) => {
  return new Date(b.data.updated).getTime() - new Date(a.data.updated).getTime();
});
---

<BaseLayout title="Library">

  <!-- ── Controls bar: search + count + filters ── -->
  <div class="controls-bar">
    <form action="/search-results" method="get" class="search-form">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="8.5" cy="8.5" r="6.5" stroke="currentColor" stroke-width="2"/>
        <path d="M13.5 13.5L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        name="q"
        class="search-input"
        placeholder="SEARCH ENTRIES..."
        aria-label="Search specifications"
      />
    </form>

    <span class="entry-count" id="entry-count">SHOWING {specs.length} ENTRIES</span>

    <div class="filter-pills">
      <button class="filter-pill active" data-filter="all">ALL</button>
      <button class="filter-pill" data-filter="spec">SPEC</button>
      <button class="filter-pill" data-filter="antipattern">ANTI-PATTERN</button>
      <button class="filter-pill" data-filter="reference-app">REFERENCE APP</button>
      <button class="filter-pill" data-filter="pattern">PATTERN</button>
      <button class="filter-pill" data-filter="philosophy">PHILOSOPHY</button>
    </div>
  </div>

  <!-- ── Card Grid ── -->
  <div class="spec-grid" id="spec-grid">
    {specs.map((spec) => {
      const statsFragments: string[] = [];
      if (spec.data.antipatterns) statsFragments.push(`${spec.data.antipatterns} ANTI-PATTERNS`);
      if (spec.data.invariants)   statsFragments.push(`${spec.data.invariants} INVARIANTS`);
      const statsLine = statsFragments.join(' \u2022 ');

      return (
        <article
          class="spec-card"
          data-category={spec.data.category}
          data-title={spec.data.title.toLowerCase()}
          data-summary={spec.data.summary.toLowerCase()}
          data-tags={spec.data.tags?.join(' ').toLowerCase() ?? ''}
          data-author={spec.data.author.toLowerCase()}
        >
          {/* Category banner ribbon */}
          <div class="card-banner">
            {spec.data.category.toUpperCase().replace('-', ' ')}
          </div>

          {/* Main card body */}
          <div class="card-body">
            {/* Ornamental corner accents */}
            <span class="corner corner-tl" aria-hidden="true">◆</span>
            <span class="corner corner-tr" aria-hidden="true">◆</span>

            <h2 class="card-title">
              <a href={`/e/${spec.id}`}>{spec.data.title}</a>
            </h2>

            {/* Ornamental divider */}
            <div class="card-divider" aria-hidden="true">
              <span class="divider-line"></span>
              <span class="divider-gem">◆</span>
              <span class="divider-line"></span>
            </div>

            {/* Chili rating */}
            {spec.data.spiceLevel != null && (
              <div class="card-spice" aria-label={`Spice level ${spec.data.spiceLevel} of 5`}>
                {Array.from({ length: 5 }, (_, i) => (
                  <img
                    src="/assets/chili-icon-transparent.png"
                    class={`chili-icon ${i < (spec.data.spiceLevel ?? 0) ? 'chili-active' : 'chili-inactive'}`}
                    alt=""
                    aria-hidden="true"
                    width="18"
                    height="18"
                  />
                ))}
              </div>
            )}

            {/* Stats line */}
            {statsLine && (
              <p class="card-stats">{statsLine}</p>
            )}
          </div>

          {/* Footer slug */}
          <a class="card-slug-footer" href={`/e/${spec.id}`} tabindex="-1" aria-hidden="true">
            spicy-specs.com/e/{spec.id}
          </a>
        </article>
      );
    })}
  </div>

</BaseLayout>

<!-- ────────────────────────────────────────────────────────────
     STYLES
──────────────────────────────────────────────────────────── -->
<style>

  /* ── Controls bar ── */

  .controls-bar {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding: 1.5rem 0 2rem;
    border-bottom: 1px solid var(--border-divider);
    margin-bottom: 2rem;
  }

  /* Search */
  .search-form {
    position: relative;
    flex: 0 0 auto;
    width: 240px;
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
    width: 14px;
    height: 14px;
  }

  .search-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.55rem 0.75rem 0.55rem 2.25rem;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--border-card);
    border-radius: 20px;
    color: var(--text-heading);
    transition: background 0.2s;
  }

  .search-input::placeholder { color: var(--text-muted); opacity: 0.8; }
  .search-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.85);
    border-color: var(--color-deep-red);
  }

  /* Entry count */
  .entry-count {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    white-space: nowrap;
    flex: 1 1 auto;
    text-align: center;
  }

  /* Filter pills */
  .filter-pills {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .filter-pill {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-card);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.45);
    color: var(--text-body);
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .filter-pill:hover {
    border-color: var(--color-deep-red);
    color: var(--color-deep-red);
  }

  .filter-pill.active {
    background: var(--color-deep-red);
    color: #F5EDD5;
    border-color: var(--color-deep-red);
  }


  /* ── CARD GRID ── */

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1400px) { .spec-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 1100px) { .spec-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 800px)  { .spec-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px)  { .spec-grid { grid-template-columns: 1fr; } }


  /* ── CARD ──
     Portrait 4:5 cards with parchment texture and category-colored
     ornamental double-border. */

  .spec-card {
    /* Category color drives borders and accents via CSS variable */
    --cat-color: #443322;

    aspect-ratio: 4 / 5;
    background-color: #F4E4C1;
    background-image: url('/assets/parchment-background-texture.png');
    background-size: cover;
    background-position: center;

    /* Double-border effect: outer border + inner inset shadow */
    border: 2px solid var(--cat-color);
    box-shadow:
      inset 0 0 0 1px var(--cat-color),           /* inner border */
      inset 0 0 0 4px transparent,                  /* gap */
      inset 0 0 0 5px rgba(68, 51, 34, 0.15),       /* second inner border */
      5px 5px 0 rgba(0, 0, 0, 0.12),                /* offset shadow */
      0 4px 12px rgba(0, 0, 0, 0.12);               /* soft shadow */

    border-radius: 3px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    position: relative;
    cursor: pointer;
  }

  .spec-card:hover {
    transform: translateY(-5px) rotate(-0.3deg);
    box-shadow:
      inset 0 0 0 1px var(--cat-color),
      inset 0 0 0 4px transparent,
      inset 0 0 0 5px rgba(68, 51, 34, 0.15),
      6px 10px 0 rgba(0, 0, 0, 0.15),
      0 8px 20px rgba(0, 0, 0, 0.18);
  }

  /* Category color assignment */
  .spec-card[data-category="spec"]          { --cat-color: #8B1A1A; }
  .spec-card[data-category="antipattern"]   { --cat-color: #2A5A3A; }
  .spec-card[data-category="pattern"]       { --cat-color: #B8870B; }
  .spec-card[data-category="reference-app"] { --cat-color: #B8870B; }
  .spec-card[data-category="philosophy"]    { --cat-color: #1A1208; }

  .spec-card.hidden { display: none; }


  /* ── Category banner ── */
  .card-banner {
    flex: 0 0 auto;
    padding: 0.4rem 0.5rem;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #F5EDD5;
    background-color: var(--cat-color);
    /* Small category-colored pill bump below */
    border-bottom: 2px solid rgba(0, 0, 0, 0.2);
  }

  /* ── Card body: title + divider + spice + stats ── */
  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0.6rem;
    gap: 0.6rem;
    position: relative;
  }

  /* Corner ornament diamonds */
  .corner {
    position: absolute;
    font-size: 0.4rem;
    color: var(--cat-color);
    opacity: 0.6;
    line-height: 1;
  }
  .corner-tl { top: 0.4rem; left: 0.5rem; }
  .corner-tr { top: 0.4rem; right: 0.5rem; }


  /* Card title */
  .card-title {
    margin: 0;
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: clamp(0.65rem, 1.5vw, 0.85rem);
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-title a {
    color: var(--color-dark-brown);
    text-decoration: none;
    display: block;
  }

  .card-title a:hover { color: var(--cat-color); }


  /* Ornamental divider */
  .card-divider {
    display: flex;
    align-items: center;
    width: 80%;
    gap: 0.3rem;
    color: var(--cat-color);
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background-color: var(--cat-color);
    opacity: 0.5;
  }

  .divider-gem {
    font-size: 0.45rem;
    line-height: 1;
    color: var(--cat-color);
  }


  /* Chili rating icons */
  .card-spice {
    display: flex;
    gap: 0.15rem;
    align-items: center;
  }

  .chili-icon {
    width: 14px;
    height: 14px;
    object-fit: contain;
  }

  /* Active: tint the cream chili icon to the category color.
     Technique: sepia converts cream → warm golden, then hue-rotate + saturate push to target hue. */
  .spec-card[data-category="spec"] .chili-active {
    filter: sepia(1) hue-rotate(330deg) saturate(8) brightness(0.5);
  }
  .spec-card[data-category="antipattern"] .chili-active {
    filter: sepia(1) hue-rotate(80deg) saturate(8) brightness(0.4);
  }
  .spec-card[data-category="pattern"] .chili-active,
  .spec-card[data-category="reference-app"] .chili-active {
    filter: sepia(1) saturate(5) brightness(0.7);
  }
  .spec-card[data-category="philosophy"] .chili-active {
    filter: sepia(1) saturate(2) brightness(0.38);
  }

  /* Inactive: ghosted but still legible */
  .chili-inactive {
    filter: grayscale(1);
    opacity: 0.3;
  }


  /* Stats line */
  .card-stats {
    font-family: var(--font-body);
    font-size: 0.52rem;
    letter-spacing: 0.08em;
    color: var(--color-medium-brown);
    text-align: center;
    margin: 0;
    line-height: 1.3;
  }


  /* ── Footer slug ── */
  .card-slug-footer {
    flex: 0 0 auto;
    display: block;
    background-color: #1A1208;
    padding: 0.35rem 0.75rem;
    text-align: center;
    text-decoration: none;
    border-top: 1px solid rgba(0,0,0,0.3);
  }

  .card-slug-footer:hover {
    background-color: #2C1E0F;
  }

  .card-slug-footer {
    font-family: var(--font-code);
    font-size: 0.5rem;
    color: rgba(245, 237, 213, 0.65);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.02em;
  }

</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput  = document.querySelector<HTMLInputElement>('.search-input');
    const filterPills  = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const cards        = document.querySelectorAll<HTMLElement>('.spec-card');
    const countEl      = document.querySelector<HTMLElement>('#entry-count');

    let currentFilter = 'all';
    let currentSearch = '';

    function refreshCount() {
      const n = document.querySelectorAll('.spec-card:not(.hidden)').length;
      if (countEl) countEl.textContent = `SHOWING ${n} ENTR${n === 1 ? 'Y' : 'IES'}`;
    }

    function applyFilters() {
      const search = currentSearch.toLowerCase();
      cards.forEach(card => {
        const matchesFilter =
          currentFilter === 'all' || card.dataset.category === currentFilter;
        const matchesSearch =
          !search ||
          (card.dataset.title ?? '').includes(search) ||
          (card.dataset.summary ?? '').includes(search) ||
          (card.dataset.tags ?? '').includes(search) ||
          (card.dataset.author ?? '').includes(search);
        card.classList.toggle('hidden', !(matchesFilter && matchesSearch));
      });
      refreshCount();
    }

    searchInput?.addEventListener('input', e => {
      currentSearch = (e.target as HTMLInputElement).value;
      applyFilters();
    });

    filterPills.forEach(pill => {
      pill.addEventListener('click', () => {
        filterPills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        currentFilter = pill.dataset.filter ?? 'all';
        applyFilters();
      });
    });

    // Make whole card clickable
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const link = card.querySelector<HTMLAnchorElement>('.card-title a');
        if (link) window.location.href = link.href;
      });
    });

    refreshCount();
  });
</script>
