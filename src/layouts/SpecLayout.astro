---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  category: string;
  spiceLevel?: number;
  tags?: string[];
  summary: string;
  created: string;
  updated: string;
  author: string;
  antipatterns?: number;
  invariants?: number;
}

const {
  title,
  category,
  spiceLevel,
  tags,
  summary,
  created,
  updated,
  author,
  antipatterns,
  invariants,
} = Astro.props;

// Inline chili rating array
const chiliCount = spiceLevel ?? 0;

const categoryColor: Record<string, string> = {
  spec:            '#8B1A1A',
  antipattern:     '#2A5A3A',
  pattern:         '#B8870B',
  'reference-app': '#B8870B',
  philosophy:      '#1A1208',
};
const catColor = categoryColor[category] ?? '#443322';

const statsFragments: string[] = [];
if (antipatterns) statsFragments.push(`${antipatterns} anti-patterns`);
if (invariants)   statsFragments.push(`${invariants} invariants`);
const statsLine = statsFragments.join(' · ');
---

<BaseLayout title={title} description={summary}>
  <article class="spec-page" data-category={category}>

    <!-- Breadcrumb -->
    <nav class="spec-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Library</a>
      <span aria-hidden="true">›</span>
      <span class="breadcrumb-category">{category}</span>
    </nav>

    <!-- Header: Title + meta -->
    <header class="spec-header">
      <div class="spec-category-banner">{category.toUpperCase().replace('-', ' ')}</div>

      <h1 class="spec-title">{title}</h1>

      <!-- Ornamental divider -->
      <div class="spec-divider" aria-hidden="true">
        <span class="spec-divider-line"></span>
        <span class="spec-divider-gem">◆</span>
        <span class="spec-divider-line"></span>
      </div>

      <!-- Spice rating -->
      {chiliCount > 0 && (
        <div class="spec-spice-row" aria-label={`Spice level ${chiliCount} of 5`}>
          {Array.from({ length: 5 }, (_, i) => (
            <img
              src="/assets/chili-icon-transparent.png"
              class={`spec-chili ${i < chiliCount ? 'chili-active' : 'chili-inactive'}`}
              alt=""
              aria-hidden="true"
              width="20"
              height="20"
            />
          ))}
        </div>
      )}

      {statsLine && <p class="spec-stats">{statsLine}</p>}

      <p class="spec-summary">{summary}</p>

      <!-- Meta row -->
      <div class="spec-meta-row">
        <span>By {author}</span>
        <span>·</span>
        <span>Published {created}</span>
        {updated !== created && (
          <>
            <span>·</span>
            <span>Updated {updated}</span>
          </>
        )}
      </div>

      {tags && tags.length > 0 && (
        <div class="spec-tags">
          {tags.map(tag => <span class="spec-tag">#{tag}</span>)}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="spec-content">
      <slot />
    </div>

    <!-- Footer nav -->
    <nav class="spec-footer-nav">
      <a href="/" class="back-link">← Back to Library</a>
    </nav>

  </article>
</BaseLayout>

<style define:vars={{ catColor }}>
  .spec-page {
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
    padding-bottom: var(--spacing-xl);
  }

  /* Breadcrumb */
  .spec-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: var(--spacing-lg);
    padding-top: var(--spacing-md);
  }

  .spec-breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .spec-breadcrumb a:hover { color: var(--color-deep-red); }

  .breadcrumb-category {
    text-transform: uppercase;
    font-weight: 700;
    color: var(--catColor);
    letter-spacing: 0.1em;
  }

  /* ── Spec header ── */
  .spec-header {
    text-align: center;
    border-bottom: 1px solid var(--border-divider);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .spec-category-banner {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #F5EDD5;
    background-color: var(--catColor);
    padding: 0.3rem 1.25rem;
    border-radius: 2px;
    margin-bottom: var(--spacing-md);
  }

  .spec-title {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-dark-brown);
    line-height: 1.2;
    margin: 0 0 var(--spacing-md);
  }

  /* Ornamental divider */
  .spec-divider {
    display: flex;
    align-items: center;
    width: 60%;
    margin: 0 auto var(--spacing-md);
    gap: 0.5rem;
    color: var(--catColor);
  }

  .spec-divider-line {
    flex: 1;
    height: 1px;
    background-color: var(--catColor);
    opacity: 0.4;
  }

  .spec-divider-gem {
    font-size: 0.6rem;
    line-height: 1;
  }

  /* Chili rating */
  .spec-spice-row {
    display: flex;
    justify-content: center;
    gap: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .spec-chili {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  /* Colorize cream chili icon: sepia converts cream → warm golden, then rotate/saturate to target hue */
  .chili-active {
    filter: sepia(1) hue-rotate(330deg) saturate(8) brightness(0.5);
  }

  .spec-page[data-category="antipattern"] .chili-active {
    filter: sepia(1) hue-rotate(80deg) saturate(8) brightness(0.4);
  }

  .spec-page[data-category="pattern"] .chili-active,
  .spec-page[data-category="reference-app"] .chili-active {
    filter: sepia(1) saturate(5) brightness(0.7);
  }

  .spec-page[data-category="philosophy"] .chili-active {
    filter: sepia(1) saturate(1) brightness(0.2);
  }

  .chili-inactive {
    filter: grayscale(1) brightness(1.5);
    opacity: 0.2;
  }

  /* Stats */
  .spec-stats {
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin: 0 0 var(--spacing-sm);
  }

  /* Summary */
  .spec-summary {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--text-body);
    line-height: var(--line-normal);
    max-width: 680px;
    margin: 0 auto var(--spacing-sm);
  }

  /* Meta row */
  .spec-meta-row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    color: var(--text-muted);
    margin-bottom: var(--spacing-sm);
  }

  /* Tags */
  .spec-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
  }

  .spec-tag {
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
    background: rgba(139, 26, 26, 0.1);
    color: var(--color-deep-red);
    border: 1px solid rgba(139, 26, 26, 0.2);
    letter-spacing: 0.04em;
  }

  /* ── Content body ── */

  :global(.spec-content > *:first-child) { margin-top: 0; }

  :global(.spec-content h2) {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-dark-brown);
    margin-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xs);
    border-bottom: 2px solid var(--border-divider);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  :global(.spec-content h2::before),
  :global(.spec-content h2::after) {
    content: '◆';
    font-size: 0.5rem;
    color: var(--color-deep-red);
    opacity: 0.6;
    flex-shrink: 0;
  }

  :global(.spec-content h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-top: var(--spacing-lg);
  }

  :global(.spec-content p) {
    line-height: var(--line-normal);
    margin-bottom: var(--spacing-sm);
  }

  :global(.spec-content ul),
  :global(.spec-content ol) {
    margin-left: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  :global(.spec-content li) {
    margin-bottom: 0.4rem;
    line-height: var(--line-normal);
  }

  :global(.spec-content table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--spacing-md) 0;
    font-size: var(--text-small);
  }

  :global(.spec-content th) {
    background-color: var(--color-dark-brown);
    color: #F5EDD5;
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-tiny);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  :global(.spec-content td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-divider);
    vertical-align: top;
  }

  :global(.spec-content tr:nth-child(even) td) {
    background-color: rgba(0, 0, 0, 0.03);
  }

  :global(.spec-content blockquote) {
    border-left: 3px solid var(--color-deep-red);
    padding-left: var(--spacing-md);
    margin-left: 0;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Footer nav */
  .spec-footer-nav {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-divider);
  }

  .back-link {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 700;
    color: var(--color-deep-red);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .back-link:hover { text-decoration: underline; }
</style>
