---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Curated library of specs, patterns, and anti-patterns for AI agents',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Spicy Specs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Merriweather:wght@400;700&family=Cinzel:wght@400;700;900&display=swap" rel="stylesheet" />
  </head>
  <body>

    <header class="site-header">
      <!--
        The logo image is the CSS background-image of .header-logo-area.
        The tagline and rule live INSIDE .header-logo-area so background-size:cover
        extends the image to fill the full header — no separate CSS background region,
        no colour seam.
      -->
      <a href="/" class="header-logo-link" aria-label="Spicy Specs — Home">
        <div class="header-logo-area">
          <p class="site-tagline">PATTERN LIBRARY &bull; EST. 2026</p>
          <div class="header-rule" aria-hidden="true"></div>
        </div>
      </a>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-rule" aria-hidden="true"></div>
        <p class="footer-text">&copy; 2026 Spicy Specs &bull; Bottled for Human &amp; Agent Consumption</p>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ============================================================
     SITE HEADER
     ============================================================ */

  /* Minimal shell — no background-color so the logo area fills it entirely */
  .site-header {
    line-height: 0; /* remove inline-block gap under .header-logo-link */
  }

  .header-logo-link {
    display: block;
    text-decoration: none;
  }

  /*
   * header-logo-area
   * ─────────────────
   * The generated wide logo PNG (1600×280, aspect ≈ 5.7:1) is the background.
   * background-size: cover ensures it always fills the full box.
   *
   * Height is built from two layers of padding:
   *   padding-top  = 17.5% (= 280/1600) preserves the logo's natural aspect ratio
   *   padding-bottom contains the tagline text
   *
   * Because the tagline sits INSIDE this element, cover extends to fill it —
   * one continuous image surface, zero CSS-vs-image colour seam.
   */
  .header-logo-area {
    width: 100%;
    padding-top: 17.5%;       /* logo natural aspect ratio: 280/1600 */
    padding-bottom: 1.4rem;   /* space for tagline + rule */
    background-image: url('/assets/header-logo-wide.png');
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    background-color: #8B1A1A; /* shown only if image fails to load */
    position: relative;
    line-height: 1.5;         /* restore line-height for text children */
  }

  /* "PATTERN LIBRARY • EST. 2026" — floats on the image surface */
  .site-tagline {
    font-family: 'Merriweather', Georgia, serif;
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    color: rgba(245, 237, 213, 0.65);
    text-transform: uppercase;
    text-align: center;
    margin: 0;
    padding: 0.55rem 0 0.6rem;
    padding-left: 0.32em; /* compensate letter-spacing on last char */
  }

  /* CSS-only ornamental separator — two thin cream lines with a gap */
  .header-rule {
    height: 7px;
    border-top: 1px solid rgba(245, 237, 213, 0.35);
    border-bottom: 1px solid rgba(245, 237, 213, 0.18);
    line-height: 0;
  }

  /* ============================================================
     FOOTER
     ============================================================ */

  .site-footer {
    margin-top: var(--spacing-xl);
    padding: 0 0 var(--spacing-lg);
    text-align: center;
  }

  .footer-rule {
    height: 7px;
    border-top: 1px solid var(--border-divider);
    border-bottom: 1px solid rgba(136, 119, 102, 0.3);
    margin-bottom: var(--spacing-md);
    line-height: 0;
  }

  .footer-text {
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0;
  }
</style>
